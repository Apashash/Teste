# =============================================================
# Variables d'environnement requises pour AshtechPay
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================

# Port du serveur Node.js (Plesk assigne souvent 3000 ou autre)
PORT=3000

# Environnement (production ou development)
NODE_ENV=production

# Clé API AshtechPay — OBLIGATOIRE
# Obtenez votre clé sur ashtechpay.top
ASHTECH_PAY_API_KEY=ak_live_xxxxxxxxxxxxxxxxxxxxxxxx
